      "min": 18,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "heading_size_tablet",
      "label": "Encabezado (tablet)",
      "min": 18,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 36
