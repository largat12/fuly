{%- comment -%}
  FULY Home — Testimonials (section 10). Horizontal scroll carousel with prev/next arrows.
{%- endcomment -%}
{%- liquid
  assign tag_label = section.settings.tag_label | default: 'TESTIMONIOS'
  assign heading = section.settings.heading | default: 'LO QUE DICEN LAS FAMILIAS'
-%}
{%- style -%}
  #shopify-section-{{ section.id }} {
    --r-card-width: {{ section.settings.card_width_mobile | default: 260 }}px;
    --r-text-size: {{ section.settings.text_size_mobile | default: 16 }}px;
    --r-track-gap: {{ section.settings.track_gap_mobile | default: 16 }}px;
    --r-heading-size: {{ section.settings.heading_size_mobile | default: 28 }}px;
    --r-pad-block: {{ section.settings.padding_block_mobile | default: 48 }}px;
    --r-star-color: {{ section.settings.star_color | default: '#F7CD47' }};
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} {
      --r-card-width: {{ section.settings.card_width_tablet | default: 280 }}px;
      --r-text-size: {{ section.settings.text_size_tablet | default: 16 }}px;
      --r-track-gap: {{ section.settings.track_gap_tablet | default: 16 }}px;
      --r-heading-size: {{ section.settings.heading_size_tablet | default: 36 }}px;
      --r-pad-block: {{ section.settings.padding_block_tablet | default: 96 }}px;
    }
  }
  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} {
      --r-card-width: {{ section.settings.card_width_desktop | default: 280 }}px;
      --r-text-size: {{ section.settings.text_size_desktop | default: 16 }}px;
      --r-track-gap: {{ section.settings.track_gap_desktop | default: 16 }}px;
      --r-heading-size: {{ section.settings.heading_size_desktop | default: 44 }}px;
      --r-pad-block: {{ section.settings.padding_block_desktop | default: 96 }}px;
    }
  }
  #shopify-section-{{ section.id }} .fuly-section-padding { padding-top: var(--r-pad-block); padding-bottom: var(--r-pad-block); }
  #shopify-section-{{ section.id }} .fuly-testimonials-track { gap: var(--r-track-gap); }
  #shopify-section-{{ section.id }} .fuly-testimonial-card { min-width: var(--r-card-width); max-width: var(--r-card-width); }
  #shopify-section-{{ section.id }} .fuly-testimonial-text { font-size: var(--r-text-size); }
  #shopify-section-{{ section.id }} .fuly-testimonial-stars { color: var(--r-star-color); }
  #shopify-section-{{ section.id }} .fuly-section-head h2 { font-size: var(--r-heading-size); }
{%- endstyle -%}
<section class="fuly-section-padding fuly-lab-grid-bg" data-fuly-testimonials-section>
  <div class="fuly-container">
    <div class="fuly-section-head">
      <span class="fuly-tag-label">{{ tag_label }}</span>
      <h2>{{ heading }}</h2>
    </div>

    <div class="fuly-testimonials-wrap">
      <button
        type="button"
        class="fuly-testimonials-arrow fuly-testimonials-arrow--prev"
        aria-label="Anterior"
        data-fuly-testimonials-prev
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="fuly-testimonials-track" data-fuly-testimonials-track>
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <article class="fuly-testimonial-card" {{ block.shopify_attributes }}>
              <div class="fuly-testimonial-stars" aria-label="5 estrellas">
                {%- for i in (1..5) -%}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                  </svg>
                {%- endfor -%}
              </div>
              <p class="fuly-testimonial-text">"{{ block.settings.text }}"</p>
              <div>
                <p class="fuly-testimonial-name">{{ block.settings.name }}</p>
                <p class="fuly-testimonial-city">{{ block.settings.city }}</p>
                <span class="fuly-testimonial-tag">{{ block.settings.product_tag }}</span>
              </div>
            </article>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <button
        type="button"
        class="fuly-testimonials-arrow fuly-testimonials-arrow--next"
        aria-label="Siguiente"
        data-fuly-testimonials-next
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  {%- if section.settings.heading_font != blank and section.settings.heading_font != 'inherit' -%}
  #shopify-section-{{ section.id }} h1,
  #shopify-section-{{ section.id }} h2,
  #shopify-section-{{ section.id }} h3,
  #shopify-section-{{ section.id }} h4 { font-family: {% render 'fuly-font-stack', choice: section.settings.heading_font, picker: section.settings.heading_font_picker %} !important; }
  {%- endif -%}
  {%- if section.settings.body_font != blank and section.settings.body_font != 'inherit' -%}
  #shopify-section-{{ section.id }} p,
  #shopify-section-{{ section.id }} li,
  #shopify-section-{{ section.id }} summary,
  #shopify-section-{{ section.id }} blockquote { font-family: {% render 'fuly-font-stack', choice: section.settings.body_font, picker: section.settings.body_font_picker %} !important; }
  {%- endif -%}
</style>

{% schema %}
{
