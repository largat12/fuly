    {
      "type": "range",
      "id": "card_width_tablet",
      "label": "Ancho tarjeta (tablet)",
      "min": 200,
      "max": 400,
      "step": 5,
      "unit": "px",
      "default": 280
    },
    {
      "type": "range",
      "id": "card_width_desktop",
      "label": "Ancho tarjeta (desktop)",
      "min": 200,
      "max": 400,
      "step": 5,
      "unit": "px",
      "default": 280
    },
    {
      "type": "header",
      "content": "Responsive — Texto de testimonio"
