<div class="fuly-nosotros fuly-lab-grid-bg">
  <section class="fuly-nosotros-section">
    <div class="fuly-nosotros-container fuly-nosotros-container--narrow">
      {% if section.settings.tag_label != blank %}
        <span class="fuly-tag-label">{{ section.settings.tag_label }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="fuly-nosotros-h2">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.copy != blank %}
        <p class="fuly-nosotros-p">{{ section.settings.copy }}</p>
      {% endif %}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Nosotros — Creencia",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "tag_label",
      "label": "Etiqueta",
      "default": "LO QUE CREEMOS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título (h2)",
      "default": "Cada niño merece crecer con superpoderes"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Párrafo",
      "default": "Creemos que la nutrición es el superpoder más subestimado. Un niño bien nutrido piensa mejor, duerme mejor, se enferma menos y juega más. Y una familia que le da buena nutrición a sus hijos no solo cuida un cuerpo: está construyendo el futuro."
    }
  ],
  "presets": [
    {
      "name": "Nosotros — Creencia"
    }
  ]
}
{% endschema %}
