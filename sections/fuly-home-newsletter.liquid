    },
    {
      "type": "font_picker",
      "id": "heading_font_picker",
      "label": "Fuente personalizada (títulos)",
      "default": "assistant_n4"
    },
    {
      "type": "select",
      "id": "body_font",
      "label": "Fuente del texto",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "Predeterminada (del tema)"
        },
        {
          "value": "display",
          "label": "Marca — Títulos (PP Pangram Rounded)"
        },
        {
          "value": "body",
          "label": "Marca — Cuerpo (Arial)"
        },
        {
          "value": "mono",
          "label": "Marca — Martian Mono"
        },
        {
          "value": "shopify_heading",
          "label": "Shopify — Fuente de títulos"
        },
        {
          "value": "shopify_body",
          "label": "Shopify — Fuente de cuerpo"
        },
