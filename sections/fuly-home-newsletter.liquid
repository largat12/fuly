      "default": 16
    },
    {
      "type": "range",
      "id": "body_size_tablet",
      "label": "Cuerpo — Tablet",
      "unit": "px",
      "min": 12,
      "max": 32,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "body_size_desktop",
      "label": "Cuerpo — Desktop",
      "unit": "px",
      "min": 12,
      "max": 32,
      "step": 1,
      "default": 16
    },
    {
      "type": "header",
      "content": "Responsive — Tamaño del input"
    },
    {
      "type": "range",
      "id": "input_size_mobile",
      "label": "Input — Móvil",
      "unit": "px",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "input_size_tablet",
      "label": "Input — Tablet",
      "unit": "px",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "input_size_desktop",
      "label": "Input — Desktop",
      "unit": "px",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 14
    },
