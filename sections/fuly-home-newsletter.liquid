{%- comment -%}
  FULY Home — Newsletter (section 12). Cyan (#0EB680) full-bleed band, uses Shopify customer form.
{%- endcomment -%}
{%- liquid
  assign heading = section.settings.heading | default: 'ÚNETE AL FULYVERSO'
  assign body = section.settings.body | default: 'Descuentos exclusivos, lanzamientos y herramientas para una crianza más fácil.'
  assign badge = section.settings.badge | default: 'RECIBE 10% EN TU PRIMERA COMPRA'
  assign placeholder = section.settings.placeholder | default: 'tu@email.com'
  assign submit_label = section.settings.submit_label | default: 'Suscribirme'
-%}
{%- style -%}
  #shopify-section-{{ section.id }} {
    --r-heading-size: {{ section.settings.heading_size_mobile | default: 32 }}px;
    --r-body-size: {{ section.settings.body_size_mobile | default: 16 }}px;
    --r-input-size: {{ section.settings.input_size_mobile | default: 14 }}px;
    --r-pad-block: {{ section.settings.padding_block_mobile | default: 48 }}px;
    --r-bg: {{ section.settings.bg_color | default: '#0EB680' }};
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} {
      --r-heading-size: {{ section.settings.heading_size_tablet | default: 36 }}px;
      --r-body-size: {{ section.settings.body_size_tablet | default: 16 }}px;
      --r-input-size: {{ section.settings.input_size_tablet | default: 14 }}px;
      --r-pad-block: {{ section.settings.padding_block_tablet | default: 64 }}px;
    }
  }
  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} {
      --r-heading-size: {{ section.settings.heading_size_desktop | default: 40 }}px;
      --r-body-size: {{ section.settings.body_size_desktop | default: 16 }}px;
      --r-input-size: {{ section.settings.input_size_desktop | default: 14 }}px;
      --r-pad-block: {{ section.settings.padding_block_desktop | default: 64 }}px;
    }
  }
  #shopify-section-{{ section.id }} .fuly-newsletter-section {
    background-color: var(--r-bg);
    padding-top: var(--r-pad-block);
    padding-bottom: var(--r-pad-block);
  }
  #shopify-section-{{ section.id }} .fuly-newsletter-section h2 { font-size: var(--r-heading-size); }
  #shopify-section-{{ section.id }} .fuly-newsletter-section p { font-size: var(--r-body-size); }
  #shopify-section-{{ section.id }} .fuly-newsletter-input { font-size: var(--r-input-size); }
  #shopify-section-{{ section.id }} .fuly-newsletter-message {
    flex-basis: 100%;
    margin: 12px 0 0;
    font-family: var(--fuly-font-heading);
    font-weight: 700;
    font-size: 15px;
  }
  #shopify-section-{{ section.id }} .fuly-newsletter-message--success { color: var(--fuly-cartoon-black); }
  #shopify-section-{{ section.id }} .fuly-newsletter-message--error { color: var(--fuly-cereza); }
{%- endstyle -%}
<section class="fuly-newsletter-section">
  <div class="fuly-newsletter-inner">
    <h2>{{ heading }}</h2>
    <p>{{ body }}</p>
    <span class="fuly-newsletter-badge">{{ badge }}</span>
    {%- form 'customer', id: 'FulyNewsletter', class: 'fuly-newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input
        type="email"
        name="contact[email]"
        class="fuly-newsletter-input"
        placeholder="{{ placeholder }}"
        aria-label="Email"
        autocorrect="off"
        autocapitalize="off"
        autocomplete="email"
        required
      >
      <button type="submit" class="fuly-cartoon-btn fuly-cartoon-btn-primary" name="commit">{{ submit_label }}</button>
      {%- if form.errors -%}
        <p class="fuly-newsletter-message fuly-newsletter-message--error" role="alert">
          {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
        </p>
      {%- elsif form.posted_successfully? -%}
        <p class="fuly-newsletter-message fuly-newsletter-message--success" role="status" tabindex="-1" autofocus>
          {{ section.settings.success_message | default: '¡Gracias por suscribirte! 🎉' }}
        </p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

<style>
  {%- if section.settings.heading_font != blank and section.settings.heading_font != 'inherit' -%}
  #shopify-section-{{ section.id }} h1,
  #shopify-section-{{ section.id }} h2,
  #shopify-section-{{ section.id }} h3,
  #shopify-section-{{ section.id }} h4 { font-family: {% render 'fuly-font-stack', choice: section.settings.heading_font, picker: section.settings.heading_font_picker %} !important; }
  {%- endif -%}
  {%- if section.settings.body_font != blank and section.settings.body_font != 'inherit' -%}
  #shopify-section-{{ section.id }} p,
  #shopify-section-{{ section.id }} li,
  #shopify-section-{{ section.id }} summary,
  #shopify-section-{{ section.id }} blockquote { font-family: {% render 'fuly-font-stack', choice: section.settings.body_font, picker: section.settings.body_font_picker %} !important; }
  {%- endif -%}
</style>

{% schema %}
{
  "name": "Fuly Home Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "ÚNETE AL FULYVERSO"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Descuentos exclusivos, lanzamientos y herramientas para una crianza más fácil."
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "RECIBE 10% EN TU PRIMERA COMPRA"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder",
      "default": "tu@email.com"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit label",
      "default": "Suscribirme"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Mensaje de éxito",
      "default": "¡Gracias por suscribirte! 🎉"
    },
    {
      "type": "header",
      "content": "Responsive — Color"
    },
    {
      "type": "color",
      "id": "bg_color",
