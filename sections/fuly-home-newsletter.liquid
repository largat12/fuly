      "max": 72,
      "step": 1,
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Título — Desktop",
      "unit": "px",
      "min": 16,
      "max": 72,
      "step": 1,
      "default": 40
    },
    {
      "type": "header",
