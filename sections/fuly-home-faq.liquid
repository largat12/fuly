{%- comment -%}
  FULY Home — FAQ (section 11). Native <details> accordion + post-FAQ CTA.
{%- endcomment -%}
{%- liquid
  assign tag_label = section.settings.tag_label | default: 'FAQ'
  assign heading = section.settings.heading | default: 'PREGUNTAS FRECUENTES'
  assign cta_heading = section.settings.cta_heading | default: '¿TIENES MÁS PREGUNTAS?'
  assign cta_label = section.settings.cta_label | default: 'ESCRÍBENOS'
  assign cta_link = section.settings.cta_link | default: '/pages/contacto'
-%}
{%- style -%}
  #shopify-section-{{ section.id }} {
    --r-heading-size: {{ section.settings.heading_size_mobile | default: 28 }}px;
    --r-question-size: {{ section.settings.question_size_mobile | default: 16 }}px;
    --r-answer-size: {{ section.settings.answer_size_mobile | default: 16 }}px;
    --r-gap: {{ section.settings.gap_mobile | default: 12 }}px;
    --r-summary-pad: {{ section.settings.summary_padding_mobile | default: 20 }}px;
    --r-pad-block: {{ section.settings.padding_block_mobile | default: 48 }}px;
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} {
      --r-heading-size: {{ section.settings.heading_size_tablet | default: 36 }}px;
      --r-question-size: {{ section.settings.question_size_tablet | default: 16 }}px;
      --r-answer-size: {{ section.settings.answer_size_tablet | default: 16 }}px;
      --r-gap: {{ section.settings.gap_tablet | default: 12 }}px;
      --r-summary-pad: {{ section.settings.summary_padding_tablet | default: 20 }}px;
      --r-pad-block: {{ section.settings.padding_block_tablet | default: 96 }}px;
    }
  }
  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} {
      --r-heading-size: {{ section.settings.heading_size_desktop | default: 44 }}px;
      --r-question-size: {{ section.settings.question_size_desktop | default: 16 }}px;
      --r-answer-size: {{ section.settings.answer_size_desktop | default: 16 }}px;
      --r-gap: {{ section.settings.gap_desktop | default: 12 }}px;
      --r-summary-pad: {{ section.settings.summary_padding_desktop | default: 20 }}px;
      --r-pad-block: {{ section.settings.padding_block_desktop | default: 96 }}px;
    }
  }
  #shopify-section-{{ section.id }} .fuly-section-padding { padding-top: var(--r-pad-block); padding-bottom: var(--r-pad-block); }
  #shopify-section-{{ section.id }} .fuly-section-head h2 { font-size: var(--r-heading-size); }
  #shopify-section-{{ section.id }} .fuly-faq-list { gap: var(--r-gap); }
  #shopify-section-{{ section.id }} .fuly-faq-item summary { font-size: var(--r-question-size); padding: var(--r-summary-pad); }
  #shopify-section-{{ section.id }} .fuly-faq-answer { font-size: var(--r-answer-size); }
{%- endstyle -%}
<section class="fuly-section-padding fuly-faq-bg fuly-lab-grid-bg">
  <div class="fuly-container-tight">
    <div class="fuly-section-head">
      <span class="fuly-tag-label">{{ tag_label }}</span>
      <h2>{{ heading }}</h2>
    </div>

    <div class="fuly-faq-list">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <details class="fuly-faq-item" {{ block.shopify_attributes }}>
            <summary>{{ block.settings.question }}</summary>
            <div class="fuly-faq-answer">{{ block.settings.answer }}</div>
          </details>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <div class="fuly-faq-post-cta">
      <h3>{{ cta_heading }}</h3>
      <a href="{{ cta_link }}" class="fuly-btn-outline">{{ cta_label }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Fuly Home FAQ",
  "settings": [
    { "type": "text", "id": "tag_label", "label": "Tag", "default": "FAQ" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "PREGUNTAS FRECUENTES" },
    { "type": "text", "id": "cta_heading", "label": "Post-FAQ heading", "default": "¿TIENES MÁS PREGUNTAS?" },
    { "type": "text", "id": "cta_label", "label": "Post-FAQ CTA label", "default": "ESCRÍBENOS" },
    { "type": "url", "id": "cta_link", "label": "Post-FAQ CTA link" },

    { "type": "header", "content": "Responsive — Tamaño de título" },
    { "type": "range", "id": "heading_size_mobile", "label": "Título — Móvil", "unit": "px", "min": 16, "max": 80, "step": 1, "default": 28 },
    { "type": "range", "id": "heading_size_tablet", "label": "Título — Tablet", "unit": "px", "min": 16, "max": 80, "step": 1, "default": 36 },
    { "type": "range", "id": "heading_size_desktop", "label": "Título — Desktop", "unit": "px", "min": 16, "max": 80, "step": 1, "default": 44 },

    { "type": "header", "content": "Responsive — Tamaño de pregunta" },
    { "type": "range", "id": "question_size_mobile", "label": "Pregunta — Móvil", "unit": "px", "min": 12, "max": 32, "step": 1, "default": 16 },
    { "type": "range", "id": "question_size_tablet", "label": "Pregunta — Tablet", "unit": "px", "min": 12, "max": 32, "step": 1, "default": 16 },
    { "type": "range", "id": "question_size_desktop", "label": "Pregunta — Desktop", "unit": "px", "min": 12, "max": 32, "step": 1, "default": 16 },

    { "type": "header", "content": "Responsive — Tamaño de respuesta" },
    { "type": "range", "id": "answer_size_mobile", "label": "Respuesta — Móvil", "unit": "px", "min": 12, "max": 32, "step": 1, "default": 16 },
    { "type": "range", "id": "answer_size_tablet", "label": "Respuesta — Tablet", "unit": "px", "min": 12, "max": 32, "step": 1, "default": 16 },
    { "type": "range", "id": "answer_size_desktop", "label": "Respuesta — Desktop", "unit": "px", "min": 12, "max": 32, "step": 1, "default": 16 },

    { "type": "header", "content": "Responsive — Separación entre items" },
    { "type": "range", "id": "gap_mobile", "label": "Separación — Móvil", "unit": "px", "min": 0, "max": 48, "step": 1, "default": 12 },
    { "type": "range", "id": "gap_tablet", "label": "Separación — Tablet", "unit": "px", "min": 0, "max": 48, "step": 1, "default": 12 },
    { "type": "range", "id": "gap_desktop", "label": "Separación — Desktop", "unit": "px", "min": 0, "max": 48, "step": 1, "default": 12 },

    { "type": "header", "content": "Responsive — Padding del summary" },
    { "type": "range", "id": "summary_padding_mobile", "label": "Padding summary — Móvil", "unit": "px", "min": 0, "max": 48, "step": 1, "default": 20 },
    { "type": "range", "id": "summary_padding_tablet", "label": "Padding summary — Tablet", "unit": "px", "min": 0, "max": 48, "step": 1, "default": 20 },
    { "type": "range", "id": "summary_padding_desktop", "label": "Padding summary — Desktop", "unit": "px", "min": 0, "max": 48, "step": 1, "default": 20 },

    { "type": "header", "content": "Responsive — Padding vertical" },
    { "type": "range", "id": "padding_block_mobile", "label": "Padding vertical — Móvil", "unit": "px", "min": 0, "max": 200, "step": 2, "default": 48 },
    { "type": "range", "id": "padding_block_tablet", "label": "Padding vertical — Tablet", "unit": "px", "min": 0, "max": 200, "step": 2, "default": 96 },
    { "type": "range", "id": "padding_block_desktop", "label": "Padding vertical — Desktop", "unit": "px", "min": 0, "max": 200, "step": 2, "default": 96 }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fuly Home — FAQ"
    }
  ]
}
{% endschema %}
