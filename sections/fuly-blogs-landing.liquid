      "unit": "px",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_block_tablet",
      "label": "Padding vertical — Tablet",
      "unit": "px",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_block_desktop",
      "label": "Padding vertical — Desktop",
      "unit": "px",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 96
    },
    {
      "type": "header",
      "content": "Tipografía"
    },
    {
