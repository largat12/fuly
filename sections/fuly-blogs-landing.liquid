      "id": "heading_font",
      "label": "Fuente de títulos",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "Predeterminada (del tema)"
        },
        {
          "value": "display",
          "label": "Marca — Títulos (PP Pangram Rounded)"
        },
        {
          "value": "body",
          "label": "Marca — Cuerpo (Arial)"
        },
        {
          "value": "mono",
          "label": "Marca — Martian Mono"
        },
        {
          "value": "shopify_heading",
          "label": "Shopify — Fuente de títulos"
        },
        {
          "value": "shopify_body",
          "label": "Shopify — Fuente de cuerpo"
        },
        {
          "value": "custom",
          "label": "Personalizada (elegir abajo)"
        }
      ]
    },
    {
      "type": "font_picker",
      "id": "heading_font_picker",
      "label": "Fuente personalizada (títulos)",
      "default": "assistant_n4"
    },
    {
      "type": "select",
      "id": "body_font",
      "label": "Fuente del texto",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "Predeterminada (del tema)"
        },
        {
          "value": "display",
          "label": "Marca — Títulos (PP Pangram Rounded)"
        },
        {
          "value": "body",
          "label": "Marca — Cuerpo (Arial)"
        },
        {
          "value": "mono",
          "label": "Marca — Martian Mono"
        },
        {
          "value": "shopify_heading",
          "label": "Shopify — Fuente de títulos"
        },
        {
          "value": "shopify_body",
          "label": "Shopify — Fuente de cuerpo"
        },
        {
          "value": "custom",
          "label": "Personalizada (elegir abajo)"
        }
      ]
    },
    {
      "type": "font_picker",
      "id": "body_font_picker",
      "label": "Fuente personalizada (texto)",
      "default": "assistant_n4"
    }
  ],
  "blocks": [
    {
      "type": "blog_card",
      "name": "Blog",
      "settings": [
        {
          "type": "blog",
          "id": "blog",
          "label": "Blog (toma título y enlace automáticamente)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título (override, opcional)"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción corta"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "color",
          "id": "accent",
          "label": "Color de acento",
          "default": "#FFE135"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace (override, opcional)"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Texto del enlace",
          "default": "Ver más →"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fuly — Más niños (blogs)",
      "blocks": [
        {
          "type": "blog_card",
          "settings": {
