<div class="fuly-semilla">
  <section class="fuly-semilla-section fuly-semilla-hero">
    <div class="fuly-semilla-hero__inner">
      <span class="fuly-semilla-badge">
        {{ section.settings.badge_text_before }}
        <svg class="fuly-semilla-badge__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 20h10"/>
          <path d="M10 20c5.5-2.5.8-6.4 3-10"/>
          <path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/>
          <path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"/>
        </svg>
        {{ section.settings.badge_text_after }}
      </span>
      <span class="fuly-tag-label">{{ section.settings.tag_label }}</span>
      <h1 class="fuly-semilla-hero__title">{{ section.settings.title }}</h1>
      <p class="fuly-semilla-hero__copy">
        {{ section.settings.copy }}
      </p>
      <button type="button" class="fuly-semilla-btn fuly-semilla-btn--accent" data-fuly-scroll-to-donate>
        {{ section.settings.button_label }}
      </button>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Give-Back — Hero",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text_before",
      "label": "Badge text (before icon)",
      "default": "FULY"
    },
    {
      "type": "text",
      "id": "badge_text_after",
      "label": "Badge text (after icon)",
      "default": "GIVE-BACK"
    },
    {
      "type": "text",
      "id": "tag_label",
      "label": "Tag label",
      "default": "FULY GIVE-BACK"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Siembra nutrición, cosecha futuro"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "Es un tratamiento de 120 dosis en un año que posibilita el desarrollo neuronal completo de niños en situación de riesgo de desnutrición."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "UNIRME"
    }
  ],
  "presets": [
    { "name": "Give-Back — Hero" }
  ]
}
{% endschema %}
