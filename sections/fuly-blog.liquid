{%- comment -%}
  FULY Blog — pixel port replicando fuly-tienda structure
  Dinámico: lista artículos de blog con filtros por tags y sort.
{%- endcomment -%}

{%- comment -%}
  Filtro por categoría: usa el enrutamiento nativo de tags de Shopify
  (/blogs/<handle>/tagged/<tag>). En esas URLs Shopify ya filtra blog.articles
  y expone current_tags. NO se puede leer ?query con Liquid (request.params no
  existe), por eso el orden se resuelve en el cliente con JS.
{%- endcomment -%}
{%- liquid
  assign active_tag = ''
  if current_tags.size > 0
    assign active_tag = current_tags.first
  endif
-%}

<section class="fuly-blog-section fuly-lab-grid-bg">
  <div class="fuly-blog-container">
    <header class="fuly-blog-header">
      <span class="fuly-tag-label">{{ section.settings.eyebrow | default: 'BLOG' }}</span>
      <h1 class="fuly-blog-title">{{ section.settings.title | default: 'Blog Fuly' }}</h1>
      <p class="fuly-blog-subtitle">{{ section.settings.subtitle | default: 'Artículos, tips y novedades sobre nutrición y bienestar' }}</p>
    </header>

    <div class="fuly-collection-toolbar">
      <div class="fuly-collection-sort fuly-blog-filter">
        <label class="fuly-collection-sr-only" for="fuly-blog-tag">{{ section.settings.filter_label | default: 'Categoría' }}</label>
        <select id="fuly-blog-tag" onchange="if(this.value){window.location.href=this.value;}">
          <option value="{{ blog.url }}"{% if active_tag == blank %} selected{% endif %}>{{ section.settings.filter_all_label }}</option>
          {%- for tag in blog.all_tags -%}
            {%- unless tag == 'Promoción' or tag == 'Destacado' -%}
              <option value="{{ blog.url }}/tagged/{{ tag | handleize }}"{% if tag == active_tag %} selected{% endif %}>{{ tag }}</option>
            {%- endunless -%}
          {%- endfor -%}
        </select>
      </div>

      <div class="fuly-collection-sort">
        <label class="fuly-collection-sr-only" for="fuly-blog-sort">{{ section.settings.sort_label }}</label>
        <select id="fuly-blog-sort" data-fuly-blog-sort>
          <option value="manual">{{ section.settings.sort_label }}</option>
          <option value="newest">Más reciente</option>
          <option value="oldest">Más antiguo</option>
          <option value="title-asc">Título A-Z</option>
        </select>
      </div>
    </div>

    {%- if blog.articles.size > 0 -%}
      <div class="fuly-blog-grid" id="fuly-blog-grid-{{ section.id }}">
        {%- for article in blog.articles -%}
          {%- render 'fuly-blog-card',
            article: article,
            btn_label: section.settings.btn_label,
            excerpt_words: section.settings.excerpt_words,
            show_date: section.settings.show_date
          -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="fuly-blog-empty">{{ section.settings.empty_message }}</p>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    var grid = document.getElementById('fuly-blog-grid-{{ section.id }}');
    var select = document.querySelector('#shopify-section-{{ section.id }} [data-fuly-blog-sort]');
    if (!grid || !select) return;

    // Conserva el orden original ("manual") para poder restaurarlo.
    var cards = Array.prototype.slice.call(grid.children);
    cards.forEach(function (card, i) { card.dataset.origIndex = i; });

    function applySort() {
      var v = select.value;
      var items = Array.prototype.slice.call(grid.children);
      items.sort(function (a, b) {
        if (v === 'title-asc') {
          return (a.dataset.sortTitle || '').localeCompare(b.dataset.sortTitle || '', 'es');
        }
        if (v === 'newest' || v === 'oldest') {
          var da = parseInt(a.dataset.sortDate || '0', 10);
          var db = parseInt(b.dataset.sortDate || '0', 10);
          return v === 'newest' ? db - da : da - db;
        }
        return parseInt(a.dataset.origIndex || '0', 10) - parseInt(b.dataset.origIndex || '0', 10);
      });
      items.forEach(function (card) { grid.appendChild(card); });
    }

    select.addEventListener('change', applySort);
  })();
</script>

<style>
  .fuly-blog-section {
    padding: 4.8rem 1.6rem;
    /* Fondo de cuadrícula (igual que tienda/búsqueda); se conserva la clase fuly-lab-grid-bg */
    background-color: #FFFFFF;
    background-image:
      linear-gradient(rgba(0, 0, 0, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.03) 1px, transparent 1px);
    background-size: 24px 24px;
  }
  @media (min-width: 768px) {
    .fuly-blog-section {
      padding: 8rem 1.6rem;
    }
  }

  .fuly-blog-container {
    max-width: 128rem;
    margin: 0 auto;
    padding: 0;
  }

  .fuly-blog-header {
    text-align: center;
    margin-bottom: 4.8rem;
  }
  @media (min-width: 768px) {
    .fuly-blog-header {
      margin-bottom: 6.4rem;
    }
  }

  .fuly-blog-title {
    font-family: 'Fuly Display', Arial, sans-serif;
    
    color: hsl(var(--cartoon-black));
    font-size: clamp(3.6rem, 5vw, 5.6rem);
    margin: 1.2rem 0 0;
    line-height: 1.1;
  }

  .fuly-blog-subtitle {
    font-family: Arial, sans-serif;
    color: rgba(0, 0, 0, 0.6);
    margin-top: 1.6rem;
    font-size: 1.6rem;
  }

  .fuly-blog-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    margin-bottom: 4rem;
    flex-wrap: wrap;
  }
  @media (max-width: 640px) {
    .fuly-blog-toolbar {
      flex-direction: column;
      align-items: stretch;
      gap: 1.6rem;
    }
  }

  .fuly-blog-filters {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    flex: 1;
  }

  .fuly-blog-chip {
    padding: 0.8rem 1.6rem;
    border-radius: 9999px;
    background: white;
    border: 1px solid #e0e0e0;
    color: #000;
    text-decoration: none;
    font-weight: 500;
    font-size: 1.4rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .fuly-blog-chip:hover {
    background: #f5f5f5;
  }
  .fuly-blog-chip--active {
    background: hsl(var(--primary, 354 100% 45%));
    color: white;
    border-color: hsl(var(--primary, 354 100% 45%));
  }

  .fuly-blog-sort {
    min-width: 200px;
  }
  .fuly-blog-sort select {
    padding: 0.8rem 1.2rem;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    font-size: 1.4rem;
    width: 100%;
    background: white;
    cursor: pointer;
  }

  .fuly-blog-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .fuly-blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }
  @media (min-width: 1024px) {
    .fuly-blog-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2.4rem;
    }
  }

  .fuly-blog-empty {
    text-align: center;
    padding: 3.2rem;
    color: rgba(0, 0, 0, 0.6);
    font-size: 1.6rem;
  }

  /* Toolbar de filtros (categoría + orden) como dropdowns en lista */
  .fuly-blog-section .fuly-collection-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.2rem;
    margin: 0 0 3.2rem;
  }
  .fuly-blog-section .fuly-collection-sort { min-width: 200px; }
  .fuly-blog-section .fuly-collection-sort select {
    width: 100%;
    padding: 1rem 1.4rem;
    border: 2px solid #1a1a1a;
    border-radius: 9999px;
    background: #fff;
    font-size: 1.4rem;
    font-weight: 700;
    cursor: pointer;
  }
  @media (max-width: 640px) {
    .fuly-blog-section .fuly-collection-toolbar { flex-direction: column; align-items: stretch; }
    .fuly-blog-section .fuly-collection-sort { min-width: 0; width: 100%; }
  }
</style>

<style>
  {%- if section.settings.heading_font != blank and section.settings.heading_font != 'inherit' -%}
  #shopify-section-{{ section.id }} h1,
  #shopify-section-{{ section.id }} h2,
  #shopify-section-{{ section.id }} h3,
  #shopify-section-{{ section.id }} h4 { font-family: {% render 'fuly-font-stack', choice: section.settings.heading_font, picker: section.settings.heading_font_picker %} !important; }
  {%- endif -%}
  {%- if section.settings.body_font != blank and section.settings.body_font != 'inherit' -%}
  #shopify-section-{{ section.id }} p,
  #shopify-section-{{ section.id }} li,
  #shopify-section-{{ section.id }} summary,
  #shopify-section-{{ section.id }} blockquote { font-family: {% render 'fuly-font-stack', choice: section.settings.body_font, picker: section.settings.body_font_picker %} !important; }
  {%- endif -%}
</style>

{% schema %}
{
  "name": "Fuly Blog",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow tag",
      "default": "BLOG"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Blog Fuly"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Artículos, tips y novedades sobre nutrición y bienestar"
    },
    {
      "type": "text",
      "id": "filter_label",
      "label": "Label del dropdown de categorías",
      "default": "Categoría"
    },
    {
      "type": "text",
      "id": "filter_all_label",
      "label": "Label para 'Ver todos'",
      "default": "Todos"
    },
    {
      "type": "text",
      "id": "sort_label",
      "label": "Label del dropdown de ordenamiento",
      "default": "Ordenar por"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Label del botón de lectura",
      "default": "Leer artículo"
    },
    {
      "type": "text",
      "id": "empty_message",
      "label": "Mensaje cuando no hay artículos",
      "default": "No hay artículos en esta categoría."
    },
    {
      "type": "number",
      "id": "excerpt_words",
      "label": "Palabras del resumen",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Mostrar fecha del artículo",
      "default": true
    },
    {
      "type": "header",
      "content": "Tipografía"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Fuente de títulos",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "Predeterminada (del tema)"
        },
        {
          "value": "display",
          "label": "Marca — Títulos (PP Pangram Rounded)"
        },
        {
          "value": "body",
          "label": "Marca — Cuerpo (Arial)"
        },
        {
          "value": "mono",
          "label": "Marca — Martian Mono"
        },
        {
          "value": "shopify_heading",
          "label": "Shopify — Fuente de títulos"
        },
        {
          "value": "shopify_body",
          "label": "Shopify — Fuente de cuerpo"
        },
        {
          "value": "custom",
          "label": "Personalizada (elegir abajo)"
        }
      ]
    },
    {
      "type": "font_picker",
      "id": "heading_font_picker",
      "label": "Fuente personalizada (títulos)",
      "default": "assistant_n4"
    },
    {
      "type": "select",
      "id": "body_font",
      "label": "Fuente del texto",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "Predeterminada (del tema)"
        },
        {
          "value": "display",
          "label": "Marca — Títulos (PP Pangram Rounded)"
        },
        {
          "value": "body",
          "label": "Marca — Cuerpo (Arial)"
        },
        {
          "value": "mono",
          "label": "Marca — Martian Mono"
        },
        {
          "value": "shopify_heading",
          "label": "Shopify — Fuente de títulos"
        },
        {
          "value": "shopify_body",
          "label": "Shopify — Fuente de cuerpo"
        },
        {
          "value": "custom",
          "label": "Personalizada (elegir abajo)"
        }
      ]
    },
    {
      "type": "font_picker",
      "id": "body_font_picker",
      "label": "Fuente personalizada (texto)",
      "default": "assistant_n4"
    }
  ]
}
{% endschema %}
