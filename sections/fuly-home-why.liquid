{%- comment -%}
  FULY Home — Why Fuly / Mission (section 9). 2-col layout: image left, copy right.
{%- endcomment -%}
{%- liquid
  assign tag_label = section.settings.tag_label | default: 'POR QUÉ FULY'
  assign heading = section.settings.heading | default: 'PARA QUE LOS NIÑOS SEAN MÁS NIÑOS'
  assign body = section.settings.body | default: 'Fuly nació para darles a las familias herramientas respaldadas por ciencia. Porque cada niño merece crecer sano, fuerte y feliz.'
  assign cta_label = section.settings.cta_label | default: 'CONOCE NUESTRA HISTORIA'
  assign cta_link = section.settings.cta_link | default: '/pages/nosotros'
-%}
{%- style -%}
  #shopify-section-{{ section.id }} {
    --r-heading-size: {{ section.settings.heading_size_mobile | default: 28 }}px;
    --r-body-size: {{ section.settings.body_size_mobile | default: 18 }}px;
    --r-gap: {{ section.settings.gap_mobile | default: 32 }}px;
    --r-pad-block: {{ section.settings.padding_block_mobile | default: 48 }}px;
    --r-heading-color: {{ section.settings.heading_color | default: '#1A1A1A' }};
    --r-body-color: {{ section.settings.body_color | default: '#555555' }};
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} {
      --r-heading-size: {{ section.settings.heading_size_tablet | default: 36 }}px;
      --r-body-size: {{ section.settings.body_size_tablet | default: 18 }}px;
      --r-gap: {{ section.settings.gap_tablet | default: 48 }}px;
      --r-pad-block: {{ section.settings.padding_block_tablet | default: 96 }}px;
    }
  }
  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} {
      --r-heading-size: {{ section.settings.heading_size_desktop | default: 44 }}px;
      --r-body-size: {{ section.settings.body_size_desktop | default: 18 }}px;
      --r-gap: {{ section.settings.gap_desktop | default: 48 }}px;
      --r-pad-block: {{ section.settings.padding_block_desktop | default: 96 }}px;
    }
  }
  #shopify-section-{{ section.id }} .fuly-section-padding { padding-top: var(--r-pad-block); padding-bottom: var(--r-pad-block); }
  #shopify-section-{{ section.id }} .fuly-why-grid { gap: var(--r-gap); }
  #shopify-section-{{ section.id }} .fuly-why-text h2 { font-size: var(--r-heading-size); color: var(--r-heading-color); }
  #shopify-section-{{ section.id }} .fuly-why-text p { font-size: var(--r-body-size); color: var(--r-body-color); }
{%- endstyle -%}
<section class="fuly-section-padding fuly-why-bg fuly-lab-grid-bg">
  <div class="fuly-container-narrow fuly-why-grid">
    <div class="fuly-why-image">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 800
          | image_tag: loading: 'lazy', alt: section.settings.image.alt | default: 'Fuly'
        }}
      {% else %}
        <span class="fuly-why-image-placeholder">Imagen modo Cotidianidad</span>
      {% endif %}
    </div>
    <div class="fuly-why-text">
      <span class="fuly-tag-label">{{ tag_label }}</span>
      <h2>{{ heading }}</h2>
      <p>{{ body }}</p>
      <a href="{{ cta_link }}" class="fuly-btn-outline">{{ cta_label }}</a>
    </div>
  </div>
</section>

<style>
  {%- if section.settings.heading_font != blank and section.settings.heading_font != 'inherit' -%}
  #shopify-section-{{ section.id }} h1,
  #shopify-section-{{ section.id }} h2,
  #shopify-section-{{ section.id }} h3,
  #shopify-section-{{ section.id }} h4 { font-family: {% render 'fuly-font-stack', choice: section.settings.heading_font, picker: section.settings.heading_font_picker %} !important; }
  {%- endif -%}
  {%- if section.settings.body_font != blank and section.settings.body_font != 'inherit' -%}
  #shopify-section-{{ section.id }} p,
  #shopify-section-{{ section.id }} li,
  #shopify-section-{{ section.id }} summary,
  #shopify-section-{{ section.id }} blockquote { font-family: {% render 'fuly-font-stack', choice: section.settings.body_font, picker: section.settings.body_font_picker %} !important; }
  {%- endif -%}
</style>

{% schema %}
{
  "name": "Fuly Home Why",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "tag_label",
      "label": "Tag",
      "default": "POR QUÉ FULY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "PARA QUE LOS NIÑOS SEAN MÁS NIÑOS"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Fuly nació para darles a las familias herramientas respaldadas por ciencia. Porque cada niño merece crecer sano, fuerte y feliz."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "CONOCE NUESTRA HISTORIA"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Responsive — Encabezado"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Encabezado (móvil)",
      "min": 18,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "heading_size_tablet",
      "label": "Encabezado (tablet)",
      "min": 18,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Encabezado (desktop)",
      "min": 18,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 44
    },
    {
      "type": "header",
      "content": "Responsive — Cuerpo de texto"
    },
    {
      "type": "range",
      "id": "body_size_mobile",
      "label": "Cuerpo (móvil)",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "body_size_tablet",
      "label": "Cuerpo (tablet)",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "body_size_desktop",
      "label": "Cuerpo (desktop)",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Responsive — Espaciado de columnas"
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap (móvil)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "gap_tablet",
      "label": "Gap (tablet)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "label": "Gap (desktop)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Responsive — Padding vertical de sección"
    },
    {
      "type": "range",
      "id": "padding_block_mobile",
      "label": "Padding vertical (móvil)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_block_tablet",
      "label": "Padding vertical (tablet)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_block_desktop",
      "label": "Padding vertical (desktop)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color",
      "id": "heading_color",
