{%- comment -%}
  FULY Home — How It Works (section 7). 3 numbered cards on lab-grid background.
{%- endcomment -%}
{%- liquid
  assign tag_label = section.settings.tag_label | default: 'CÓMO FUNCIONA'
  assign heading = section.settings.heading | default: 'ASÍ DE FÁCIL'
-%}
{%- style -%}
  #shopify-section-{{ section.id }} {
    --r-cols: {{ section.settings.cols_mobile | default: 1 }};
    --r-gap: {{ section.settings.gap_mobile | default: 24 }}px;
    --r-card-pad: {{ section.settings.card_padding_mobile | default: 32 }}px;
    --r-title-size: {{ section.settings.title_size_mobile | default: 20 }}px;
    --r-desc-size: {{ section.settings.desc_size_mobile | default: 16 }}px;
    --r-heading-size: {{ section.settings.heading_size_mobile | default: 28 }}px;
    --r-pad-block: {{ section.settings.padding_block_mobile | default: 48 }}px;
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} {
      --r-cols: {{ section.settings.cols_tablet | default: 3 }};
      --r-gap: {{ section.settings.gap_tablet | default: 24 }}px;
      --r-card-pad: {{ section.settings.card_padding_tablet | default: 32 }}px;
      --r-title-size: {{ section.settings.title_size_tablet | default: 20 }}px;
      --r-desc-size: {{ section.settings.desc_size_tablet | default: 16 }}px;
      --r-heading-size: {{ section.settings.heading_size_tablet | default: 36 }}px;
      --r-pad-block: {{ section.settings.padding_block_tablet | default: 96 }}px;
    }
  }
  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} {
      --r-cols: {{ section.settings.cols_desktop | default: 3 }};
      --r-gap: {{ section.settings.gap_desktop | default: 24 }}px;
      --r-card-pad: {{ section.settings.card_padding_desktop | default: 32 }}px;
      --r-title-size: {{ section.settings.title_size_desktop | default: 20 }}px;
      --r-desc-size: {{ section.settings.desc_size_desktop | default: 16 }}px;
      --r-heading-size: {{ section.settings.heading_size_desktop | default: 44 }}px;
      --r-pad-block: {{ section.settings.padding_block_desktop | default: 96 }}px;
    }
  }
  #shopify-section-{{ section.id }} .fuly-section-padding { padding-top: var(--r-pad-block); padding-bottom: var(--r-pad-block); }
  #shopify-section-{{ section.id }} .fuly-steps-grid { grid-template-columns: repeat(var(--r-cols), minmax(0, 1fr)); gap: var(--r-gap); }
  #shopify-section-{{ section.id }} .fuly-step-card { padding: var(--r-card-pad); }
  #shopify-section-{{ section.id }} .fuly-step-card__title { font-size: var(--r-title-size); }
  #shopify-section-{{ section.id }} .fuly-step-card__desc { font-size: var(--r-desc-size); }
  #shopify-section-{{ section.id }} .fuly-section-head h2 { font-size: var(--r-heading-size); }
{%- endstyle -%}
<section class="fuly-section-padding fuly-lab-grid-bg">
  <div class="fuly-container">
    <div class="fuly-section-head">
      <span class="fuly-tag-label">{{ tag_label }}</span>
      <h2>{{ heading }}</h2>
    </div>

    <div class="fuly-steps-grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="fuly-step-card" {{ block.shopify_attributes }}>
            <p class="fuly-step-card__num">{{ block.settings.num }}</p>
            <h3 class="fuly-step-card__title">{{ block.settings.title }}</h3>
            <p class="fuly-step-card__desc">{{ block.settings.desc }}</p>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="fuly-step-card">
          <p class="fuly-step-card__num">01</p>
          <h3 class="fuly-step-card__title">ELIGE TU FULY</h3>
          <p class="fuly-step-card__desc">Boosters, malteadas o drinks para cada momento del día.</p>
        </div>
        <div class="fuly-step-card">
          <p class="fuly-step-card__num">02</p>
          <h3 class="fuly-step-card__title">PREPÁRALO EN SEGUNDOS</h3>
          <p class="fuly-step-card__desc">Solo mezcla con agua, leche o tu bebida favorita.</p>
        </div>
        <div class="fuly-step-card">
          <p class="fuly-step-card__num">03</p>
          <h3 class="fuly-step-card__title">DISFRUTA LOS RESULTADOS</h3>
          <p class="fuly-step-card__desc">Nutrición funcional que les encanta.</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  {%- if section.settings.heading_font != blank and section.settings.heading_font != 'inherit' -%}
  #shopify-section-{{ section.id }} h1,
  #shopify-section-{{ section.id }} h2,
  #shopify-section-{{ section.id }} h3,
  #shopify-section-{{ section.id }} h4 { font-family: {% render 'fuly-font-stack', choice: section.settings.heading_font, picker: section.settings.heading_font_picker %} !important; }
  {%- endif -%}
  {%- if section.settings.body_font != blank and section.settings.body_font != 'inherit' -%}
  #shopify-section-{{ section.id }} p,
  #shopify-section-{{ section.id }} li,
  #shopify-section-{{ section.id }} summary,
  #shopify-section-{{ section.id }} blockquote { font-family: {% render 'fuly-font-stack', choice: section.settings.body_font, picker: section.settings.body_font_picker %} !important; }
  {%- endif -%}
</style>

