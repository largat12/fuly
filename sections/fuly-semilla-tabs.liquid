    {
      "type": "header",
      "content": "Pestañas"
    },
    {
      "type": "text",
      "id": "tab_once_label",
      "label": "Pestaña una vez",
      "default": "UNA VEZ"
    },
    {
      "type": "text",
      "id": "tab_monthly_label",
      "label": "Pestaña mensual",
      "default": "MENSUAL"
    },
    {
      "type": "header",
      "content": "Panel: Una vez"
    },
    {
      "type": "text",
