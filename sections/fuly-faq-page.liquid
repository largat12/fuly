{%- comment -%}
  FULY FAQ Page Section — Fully editable FAQ with categories and items
  Uses flat blocks structure (Shopify doesn't support nested blocks)
{%- endcomment -%}

<section class="fuly-faq-page fuly-section-padding fuly-lab-grid-bg">
  <div class="fuly-faq-page__container">
    <header class="fuly-faq-page__header">
      <span class="fuly-tag-label">{{ section.settings.eyebrow }}</span>
      <h1 class="fuly-faq-page__title">{{ section.settings.title }}</h1>
      <p class="fuly-faq-page__subtitle">{{ section.settings.subtitle }}</p>
    </header>

    <div class="fuly-faq-page__categories">
      {%- assign current_category = '' -%}
      {%- assign categories = '' -%}

      {%- for block in section.blocks -%}
        {%- if block.type == 'faq_item' -%}
          {%- unless categories contains block.settings.category -%}
            {%- assign categories = categories | append: block.settings.category | append: '|' -%}
          {%- endunless -%}
        {%- endif -%}
      {%- endfor -%}

      {%- assign category_list = categories | split: '|' -%}
      {%- for category in category_list -%}
        {%- if category != '' -%}
          <div class="fuly-faq-page__category">
            <h2 class="fuly-faq-page__category-title">{{ category }}</h2>
            <div class="fuly-faq-list">
              {%- for block in section.blocks -%}
                {%- if block.type == 'faq_item' and block.settings.category == category -%}
                  <details class="fuly-faq-item">
                    <summary>{{ block.settings.question }}</summary>
                    <div class="fuly-faq-answer">
                      {{ block.settings.answer }}
                    </div>
                  </details>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .fuly-faq-page__container {
    max-width: 76.8rem;
    margin: 0 auto;
    padding: 0 1.6rem;
  }
  .fuly-faq-page__header {
    text-align: center;
    margin-bottom: 4.8rem;
  }
  @media (min-width: 768px) {
    .fuly-faq-page__header {
      margin-bottom: 6.4rem;
    }
  }
  .fuly-faq-page__title {
    font-family: 'PP Pangram Sans Rounded Compressed', Arial, sans-serif;
    font-weight: 800;
    color: hsl(var(--cartoon-black));
    font-size: clamp(3.6rem, 5vw, 5.6rem);
    margin: 1.2rem 0 0;
    line-height: 1.1;
  }
  .fuly-faq-page__subtitle {
    font-family: Arial, sans-serif;
    color: rgba(0, 0, 0, 0.6);
    margin-top: 1.6rem;
    font-size: 1.6rem;
  }
  .fuly-faq-page__categories {
    display: flex;
    flex-direction: column;
    gap: 3.2rem;
  }
  @media (min-width: 768px) {
    .fuly-faq-page__categories {
      gap: 4rem;
    }
  }
  .fuly-faq-page__category-title {
    font-family: 'PP Pangram Sans Rounded Compressed', Arial, sans-serif;
    font-weight: 800;
    text-transform: uppercase;
    color: hsl(var(--cartoon-black));
    font-size: 2rem;
    margin: 0 0 1.6rem;
  }
  .fuly-faq-page__link {
    color: hsl(var(--primary, 354 100% 45%));
    text-decoration: underline;
    font-weight: 700;
  }
</style>

<style>
  {%- if section.settings.heading_font != blank and section.settings.heading_font != 'inherit' -%}
  #shopify-section-{{ section.id }} h1,
  #shopify-section-{{ section.id }} h2,
  #shopify-section-{{ section.id }} h3,
  #shopify-section-{{ section.id }} h4 { font-family: {% render 'fuly-font-stack', choice: section.settings.heading_font, picker: section.settings.heading_font_picker %} !important; }
  {%- endif -%}
  {%- if section.settings.body_font != blank and section.settings.body_font != 'inherit' -%}
  #shopify-section-{{ section.id }} p,
  #shopify-section-{{ section.id }} li,
  #shopify-section-{{ section.id }} summary,
  #shopify-section-{{ section.id }} blockquote { font-family: {% render 'fuly-font-stack', choice: section.settings.body_font, picker: section.settings.body_font_picker %} !important; }
  {%- endif -%}
</style>

