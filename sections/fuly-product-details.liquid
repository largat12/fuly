{%- comment -%}
  FULY Product Details — Información detallada del producto
  Muestra: Ingredientes, Tabla Nutricional, Cómo Preparar, Beneficios
  Usa el mismo diseño que FAQ
{%- endcomment -%}

{%- if section.settings.product_handle != blank -%}
  {%- assign product = all_products[section.settings.product_handle] -%}
{%- else -%}
  {%- assign product = product -%}
{%- endif -%}

{%- if product -%}
  <section class="fuly-product-details-section">
    <div class="fuly-container-tight">
      <div class="fuly-section-head">
        <h2>{{ section.settings.section_title }}</h2>
      </div>

      <div class="fuly-faq-list">
        {%- comment -%}
          Tabla Nutricional
        {%- endcomment -%}
        {%- assign nutrition_info = product.metafields.custom.tabla_nutricional | default: product.metafields.custom.informacion_nutricional | default: product.metafields.fuly.nutrition_info -%}
        {%- if nutrition_info != blank -%}
          <details class="fuly-faq-item">
            <summary>{{ section.settings.label_nutrition }}</summary>
            <div class="fuly-faq-answer">
              {{ nutrition_info }}
            </div>
          </details>
        {%- endif -%}

        {%- comment -%}
          Ingredientes
        {%- endcomment -%}
        {%- assign ingredients = product.metafields.custom.ingredientes | default: product.metafields.fuly.ingredients -%}
        {%- if ingredients != blank -%}
          <details class="fuly-faq-item">
            <summary>{{ section.settings.label_ingredients }}</summary>
            <div class="fuly-faq-answer">
              {{ ingredients }}
            </div>
          </details>
        {%- endif -%}

        {%- comment -%}
          Cómo Preparar
        {%- endcomment -%}
        {%- assign how_to_prepare = product.metafields.custom.como_preparar | default: product.metafields.custom.modo_preparacion | default: product.metafields.fuly.how_to_prepare -%}
        {%- if how_to_prepare != blank -%}
          <details class="fuly-faq-item">
            <summary>{{ section.settings.label_howto }}</summary>
            <div class="fuly-faq-answer">
              {{ how_to_prepare }}
            </div>
          </details>
        {%- endif -%}

        {%- comment -%}
          Beneficios
        {%- endcomment -%}
        {%- assign benefits_raw = product.metafields.custom.beneficios | default: product.metafields.fuly.benefits -%}
        {%- if benefits_raw != blank -%}
          <details class="fuly-faq-item">
            <summary>{{ section.settings.label_benefits }}</summary>
            <div class="fuly-faq-answer">
              {%- assign benefits = benefits_raw | parse_json -%}
              {%- if benefits -%}
                <ul class="fuly-benefits-list-product">
                  {%- for benefit in benefits -%}
                    <li>{{ benefit }}</li>
                  {%- endfor -%}
                </ul>
              {%- else -%}
                {{ benefits_raw }}
              {%- endif -%}
            </div>
          </details>
        {%- endif -%}

        {%- comment -%}
          Beneficio Funcional
        {%- endcomment -%}
        {%- assign functional_benefit = product.metafields.custom.beneficio_funcional | default: product.metafields.fuly.functional_benefit -%}
        {%- if functional_benefit != blank -%}
          <details class="fuly-faq-item">
            <summary>{{ section.settings.label_functional }}</summary>
            <div class="fuly-faq-answer">
              <strong>{{ functional_benefit }}</strong>
            </div>
          </details>
        {%- endif -%}

        {%- comment -%}
          Alergenos
        {%- endcomment -%}
        {%- assign allergens = product.metafields.custom.alergenos | default: product.metafields.fuly.allergens -%}
        {%- if allergens != blank -%}
          <details class="fuly-faq-item">
            <summary>{{ section.settings.label_allergens }}</summary>
            <div class="fuly-faq-answer">
              {{ allergens }}
            </div>
          </details>
        {%- endif -%}
      </div>
    </div>
  </section>

  <style>
    .fuly-product-details-section {
      padding: 4.8rem 2rem;
    }

    .fuly-product-details-section .fuly-section-head {
      margin-bottom: 2.4rem;
    }

    .fuly-product-details-section .fuly-section-head h2 {
      margin: 0;
      font-size: 2rem;
      font-weight: 800;
      text-transform: uppercase;
      color: var(--fuly-cartoon-black, #212121);
    }

    .fuly-benefits-list-product {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .fuly-benefits-list-product li {
      padding-left: 1.5rem;
      position: relative;
    }

    .fuly-benefits-list-product li:before {
      content: "✓";
      position: absolute;
      left: 0;
      font-weight: 700;
      color: #4CAF50;
    }

    @media (max-width: 749px) {
      .fuly-product-details-section {
        padding: 3rem 1.5rem;
      }

      .fuly-product-details-section .fuly-section-head h2 {
        font-size: 1.5rem;
      }
    }
  </style>
{%- else -%}
  <!-- Product not found in context -->
{%- endif -%}

{% schema %}
{
  "name": "Fuly Product Details",
  "settings": [
    {
      "type": "text",
      "id": "product_handle",
      "label": "Producto (handle/ID)",
      "info": "Dejar en blanco para usar el producto de la página actual"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Título de la sección",
      "default": "Detalles del Producto"
    },
    {
      "type": "text",
      "id": "label_nutrition",
      "label": "Label: Tabla Nutricional",
      "default": "Tabla Nutricional"
    },
    {
      "type": "text",
      "id": "label_ingredients",
      "label": "Label: Ingredientes",
      "default": "Ingredientes"
    },
    {
      "type": "text",
      "id": "label_howto",
      "label": "Label: Cómo Preparar",
      "default": "Cómo Preparar"
    },
    {
      "type": "text",
      "id": "label_benefits",
      "label": "Label: Beneficios",
      "default": "Beneficios"
    },
    {
      "type": "text",
      "id": "label_functional",
      "label": "Label: Beneficio Funcional",
      "default": "Beneficio Funcional"
    },
    {
      "type": "text",
      "id": "label_allergens",
      "label": "Label: Alergenos",
      "default": "Alergenos"
    }
  ],
  "presets": [
    {
      "name": "Fuly — Detalles del Producto",
      "settings": {
        "section_title": "Detalles del Producto",
        "label_nutrition": "Tabla Nutricional",
        "label_ingredients": "Ingredientes",
        "label_howto": "Cómo Preparar",
        "label_benefits": "Beneficios",
        "label_functional": "Beneficio Funcional",
        "label_allergens": "Alergenos"
      }
    }
  ]
}
{% endschema %}
