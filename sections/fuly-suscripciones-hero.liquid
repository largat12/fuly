{%- comment -%}
  FULY — Suscripciones: encabezado de la página de suscripciones (estilo Fuly).
{%- endcomment -%}
{%- liquid
  assign tag_label = section.settings.tag_label
  assign heading = section.settings.heading | default: 'Plan de suscripciones'
  assign subtitle = section.settings.subtitle
-%}
{%- style -%}
  #shopify-section-{{ section.id }} {
    --r-pad-block: {{ section.settings.padding_block_mobile | default: 40 }}px;
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} {
      --r-pad-block: {{ section.settings.padding_block_desktop | default: 64 }}px;
    }
  }
  #shopify-section-{{ section.id }} .fuly-section-padding { padding-top: var(--r-pad-block); padding-bottom: var(--r-pad-block); }
  #shopify-section-{{ section.id }} .fuly-section-head h1 {
    font-family: 'Fuly Display', Arial, sans-serif;
    
    text-transform: uppercase;
    line-height: 0.95;
    font-size: clamp(36px, 5vw, 64px);
    color: hsl(var(--cartoon-black));
    margin: 1.2rem 0 0;
  }
  #shopify-section-{{ section.id }} .fuly-suscripciones-hero__subtitle {
    max-width: 60rem;
    margin: 1.2rem auto 0;
    text-align: center;
    color: #555;
    font-size: 1.7rem;
    line-height: 1.6;
  }
{%- endstyle -%}

<section class="fuly-section-padding fuly-lab-grid-bg">
  <div class="fuly-container">
    <div class="fuly-section-head">
      {%- if tag_label != blank -%}
        <span class="fuly-tag-label">{{ tag_label }}</span>
      {%- endif -%}
      {%- if heading != blank -%}
        <h1>{{ heading }}</h1>
      {%- endif -%}
      {%- if subtitle != blank -%}
        <p class="fuly-suscripciones-hero__subtitle">{{ subtitle }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Suscripciones — Hero",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "tag_label", "label": "Tag (opcional)", "default": "SUSCRIPCIONES" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Plan de suscripciones" },
    { "type": "textarea", "id": "subtitle", "label": "Subtítulo", "default": "Suscríbete y ahorra para obtener beneficios especiales." },
    { "type": "header", "content": "Responsive" },
    { "type": "range", "id": "padding_block_mobile", "label": "Padding vertical — Móvil", "unit": "px", "min": 0, "max": 160, "step": 2, "default": 40 },
    { "type": "range", "id": "padding_block_desktop", "label": "Padding vertical — Desktop", "unit": "px", "min": 0, "max": 200, "step": 2, "default": 64 }
  ],
  "presets": [{ "name": "Suscripciones — Hero" }]
}
{% endschema %}
