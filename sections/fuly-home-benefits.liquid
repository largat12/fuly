      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Móvil",
      "default": 51
    },
    {
      "type": "range",
      "id": "padding_block_tablet",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Tablet",
      "default": 51
    },
    {
      "type": "range",
      "id": "padding_block_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Desktop",
      "default": 51
    },
    {
      "type": "header",
      "content": "Responsive — Espacio entre tags"
