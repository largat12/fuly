    {
      "type": "range",
      "id": "scroll_speed",
      "min": 10,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Velocidad (segundos por vuelta)",
      "default": 30
    },
    {
      "type": "header",
      "content": "Responsive — Padding vertical"
    },
    {
      "type": "range",
      "id": "padding_block_mobile",
