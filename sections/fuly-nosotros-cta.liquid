<div class="fuly-nosotros">
  <section class="fuly-nosotros-section fuly-nosotros-cta">
    <h2 class="fuly-nosotros-h2 fuly-nosotros-cta__title">{{ section.settings.heading }}</h2>
    <a href="{{ section.settings.button_link }}" class="fuly-nosotros-cta__btn">{{ section.settings.button_label }}</a>
  </section>
</div>

{% schema %}
{
  "name": "Nosotros — CTA",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "¿Listo para darle superpoderes a tu hijo?"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto del botón",
      "default": "Explorar productos"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del botón",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Nosotros — CTA"
    }
  ]
}
{% endschema %}
