<div class="fuly-semilla">
  <section class="fuly-semilla-section fuly-semilla-cta-final">
    <div class="fuly-semilla-cta-final__inner">
      <svg class="fuly-semilla-cta-final__sparkles" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>
        <path d="M20 3v4"/>
        <path d="M22 5h-4"/>
        <path d="M4 17v2"/>
        <path d="M5 18H3"/>
      </svg>
      <h2 class="fuly-semilla-cta-final__title">{{ section.settings.title }}</h2>
      <p class="fuly-semilla-cta-final__copy">{{ section.settings.copy }}</p>
      <button type="button" class="fuly-semilla-btn fuly-semilla-btn--whatsapp" data-fuly-whatsapp-button="cta-final" data-fuly-whatsapp-type="Quiero unirme" data-fuly-whatsapp-detail="Me gustaría saber cómo ayudar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
        <span>{{ section.settings.button_label }}</span>
      </button>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Give-Back — CTA Final",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Cada niño merece buena nutrición"
    },
    {
      "type": "text",
      "id": "copy",
      "label": "Texto",
      "default": "Únete a Fuly Give-Back y transforma vidas"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto del botón",
      "default": "UNIRME AHORA"
    }
  ],
  "presets": [
    {
      "name": "Give-Back — CTA Final"
    }
  ]
}
{% endschema %}
