    },
    {
      "type": "range",
      "id": "name_size_tablet",
      "label": "Nombre (tablet)",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "name_size_desktop",
      "label": "Nombre (desktop)",
